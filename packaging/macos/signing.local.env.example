# 复制为 signing.local.env 并填写真实值（该文件已被 .gitignore，不会上传 GitHub）
#
#   cp signing.local.env.example signing.local.env
#
# build.sh 会自动 source signing.local.env（若存在）。

# Apple Developer Team ID
TEAM_ID="YOUR_TEAM_ID"

# Bundle ID（与 setup_app.py / 开发者后台一致）
BUNDLE_ID="com.mythkiven.MacBroom"

# codesign 身份全名（security find-identity -v -p codesigning 输出里带引号的那段）
# Developer ID 直签分发用 Developer ID Application，不是 3rd Party Mac Developer Application
DEVELOPER_ID_APP="Developer ID Application: Your Name (${TEAM_ID})"

# notarytool 钥匙串 profile 名（xcrun notarytool store-credentials 时设定）
NOTARY_PROFILE="macbroom-notary"

# 公证用 Apple ID（仅本地备忘，也可不写）
# APPLE_ID="you@example.com"
